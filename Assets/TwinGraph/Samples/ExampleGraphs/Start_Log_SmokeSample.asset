%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 307cad0eb6a2a436ab9af77aaeb706b3, type: 3}
  m_Name: Start_Log_SmokeSample
  m_EditorClassIdentifier: Assembly-CSharp::TwinGraph.Runtime.Graph.GraphAsset
  graph:
    version: 0.1.0
    nodes:
    - id: start
      type: Start
      parameters: []
    - id: create_primitive
      type: CreatePrimitive
      parameters:
      - key: shape
        value: Cube
      - key: objectKey
        value: DemoCube
      - key: position
        value: 0,0.5,0
      - key: rotation
        value: 0,0,0
      - key: scale
        value: 1,1,1
    - id: delay
      type: Delay
      parameters:
      - key: seconds
        value: "1.0"
    - id: set_transform
      type: SetTransform
      parameters:
      - key: objectKey
        value: DemoCube
      - key: applyPosition
        value: "true"
      - key: position
        value: 1.5,0.5,0
      - key: applyRotation
        value: "true"
      - key: rotation
        value: 0,30,0
      - key: applyScale
        value: "true"
      - key: scale
        value: 1.25,1.25,1.25
    - id: log
      type: Log
      parameters:
      - key: message
        value: "[TwinGraph] Object workflow sample executed."
    links:
    - fromNodeId: start
      fromPort: Next
      toNodeId: create_primitive
    - fromNodeId: create_primitive
      fromPort: Next
      toNodeId: delay
    - fromNodeId: delay
      fromPort: Next
      toNodeId: set_transform
    - fromNodeId: set_transform
      fromPort: Next
      toNodeId: log
